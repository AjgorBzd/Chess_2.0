   <string notr="true">
QDialog {
    background-color: #2b2b2b;
}

QGroupBox {
    color: #e0c08b;
    font-family: 'Segoe UI', Arial, sans-serif;
    font-size: 18px;
    font-weight: bold;
    border: 2px solid #555555;
    border-radius: 8px;
    margin-top: 20px;
    padding-top: 15px;
}

QGroupBox::title {
    subcontrol-origin: margin;
    subcontrol-position: top left;
    left: 15px;
    padding: 0 5px;
}

QLabel, QCheckBox {
    color: #ffffff;
    font-family: 'Segoe UI', Arial, sans-serif;
    font-size: 16px;
}

QCheckBox::indicator {
    width: 20px;
    height: 20px;
}

QLineEdit {
    background-color: #1a1a1a;
    color: #ffffff;
    border: 2px solid #555555;
    border-radius: 6px;
    padding: 6px;
    font-family: 'Segoe UI', Arial, sans-serif;
    font-size: 16px;
    min-width: 80px;
}

QSpinBox {
    background-color: #1a1a1a;
    color: #ffffff;
    border: 2px solid #555555;
    border-radius: 6px;
    font-family: 'Segoe UI', Arial, sans-serif;
    font-size: 16px;
    min-width: 80px;
}

QSpinBox {
    padding-right: 25px;
}

QSpinBox QLineEdit {
    padding: 0px;
}

QSpinBox::up-button, QSpinBox::down-button {
    width: 25px;
    background-color: transparent;
}

QSpinBox::up-button:hover, QSpinBox::down-button:hover {
    background-color: #404040;
}

QSpinBox:disabled {
    background-color: #2b2b2b;
    color: #777777;
    border-color: #444444;
}

QLineEdit:focus, QSpinBox:focus {
    border-color: #e0c08b;
}

QPushButton {
    background-color: #404040;
    color: #ffffff;
    font-family: 'Segoe UI', Arial, sans-serif;
    font-size: 18px;
    font-weight: bold;
    border-width: 2px;
    border-style: solid;
    border-color: #555555;
    border-radius: 8px;
    padding: 12px;
    min-width: 120px;
}

QPushButton:hover {
    background-color: #5a5a5a;
    border-color: #777777;
}

QPushButton:pressed { background-color: #303030; }

QPushButton#btn_save { background-color: #a9cbff; color: #000000; border-color: #8bb5ff; }
QPushButton#btn_save:hover { background-color: #8bb5ff; }

QPushButton#btn_cancel { background-color: #fb8b8b; color: #000000; border-color: #e67373; }
QPushButton#btn_cancel:hover { background-color: #e67373; }
