QWidget#centralwidget {
    background: qlineargradient(x1:0, y1:0, x2:1, y2:1, stop:0 #1e1e1e, stop:1 #333333);
}

QPushButton {
    background-color: #404040;
    color: #ffffff;
    font-family: 'Segoe UI', Arial, sans-serif;
    font-size: 22px;
    font-weight: bold;
    border-width: 2px;
    border-style: solid;
    border-color: #555555;
    border-radius: 8px;
    padding: 15px;
}

QPushButton#btn_save { background-color: #a9cbff; }
QPushButton#btn_draw { background-color: #ffde8b; color: #000000; }
QPushButton#btn_resign { background-color: #fb8b8b; }

QPushButton:hover {
    background-color: #5a5a5a;
    border-color: #777777;
}

QPushButton:pressed { background-color: #303030; }

QLabel#titleLabel {
    color: #e0c08b;
    font-family: 'Georgia', 'Times New Roman', serif;
    font-size: 96px;
    font-weight: bold;
}

QPushButton#closeButton, QPushButton#btn_closeGame {
    background-color: #c0392b;
    border: none;
    border-radius: 30px;
    color: white;
    font-size: 28px;
    min-width: 60px;
    min-height: 60px;
    max-width: 60px;
    max-height: 60px;
}

QPushButton#closeButton:hover, QPushButton#btn_closeGame:hover { background-color: #e74c3c; }

QPushButton#btn_save:hover { background-color: #8bb5ff; }
QPushButton#btn_draw:hover { background-color: #e5c472; }
QPushButton#btn_resign:hover { background-color: #e67373; }

QLabel#p1Name, QLabel#p2Name {
    color: #ffffff;
    font-size: 20px;
    font-weight: bold;
}

QLabel#p1Timer, QLabel#p2Timer {
    border-width: 2px;
    border-style: solid;
    border-color: #e0c08b;
    border-radius: 5px;
    padding: 5px 15px;
    font-weight: bold;
    font-size: 24px;
    max-height: 45px;
}

QLabel#p1Timer { background-color: #ffffff; color: #000000; }

QLabel#p2Timer { background-color: #1a1a1a; color: #ffffff; }

QListWidget#listWidget_History {
